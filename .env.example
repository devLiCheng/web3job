# ==============================================================================
# RemoteWeb3 Global Environment Variables Template
# ==============================================================================

# --- Database Setup (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=web3job_user
DB_PASSWORD=web3job_secure_password
DB_NAME=remoteweb3Jobs
MYSQL_ROOT_PASSWORD=root_password_here

# --- Backend Config (Bun + Hono) ---
BACKEND_PORT=6002
NODE_ENV=development
JWT_SECRET=super_secret_jwt_token_for_remoteweb3

# --- Spider Config (Bun + Vercel AI SDK) ---
SPIDER_PORT=6004
# DeepSeek API Configuration (Compatible with OpenAI format or direct DeepSeek endpoint)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# --- Admin Dashboard Config (React + Arco Design Pro) ---
ADMIN_PORT=6001
VITE_API_URL=http://localhost:6002/api

# --- Frontend Web App (Next.js App Router) ---
FRONTEND_PORT=6003
NEXT_PUBLIC_API_URL=http://localhost:6002/api
BACKEND_INTERNAL_URL=http://localhost:6002/api
